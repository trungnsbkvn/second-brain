# /etc/gbrain.env — production env for second-brain.yplawfirm.vn.
#
# Install:
#   sudo install -m 600 -o gbrain -g gbrain gbrain.env.prod.example /etc/gbrain.env
#   sudoedit /etc/gbrain.env   # fill in real values
#
# Referenced by gbrain-http.service + gbrain-worker.service via
# EnvironmentFile=, and by cron via BASH_ENV=/etc/gbrain.env.

# --- Storage ------------------------------------------------------------------
# Local Postgres 17 + pgvector, loopback only.
DATABASE_URL=postgresql://gbrain:CHANGE-ME@127.0.0.1:5432/gbrain

# gbrain config root (config.json, PID files) — inside ReadWritePaths.
GBRAIN_HOME=/srv/gbrain/home

# --- Embeddings (local Ollama — tenant content never leaves the box) ----------
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1

# --- Chat/think/synthesize LLM (cloud) -----------------------------------------
DEEPSEEK_API_KEY=CHANGE-ME
# Optional second provider for higher-quality think/synthesize:
# ANTHROPIC_API_KEY=

# --- HTTP server ----------------------------------------------------------------
# Stable admin dashboard login token (>=32 chars): openssl rand -hex 32
GBRAIN_ADMIN_BOOTSTRAP_TOKEN=CHANGE-ME
# Behind Caddy on loopback — trust X-Forwarded-* from the proxy.
GBRAIN_HTTP_TRUST_PROXY=1
# 10 MiB uploads (Caddy caps at 12MB above this).
GBRAIN_HTTP_MAX_BODY_BYTES=10485760

# --- Marketplace registry (/api/catalog/*) ---------------------------------------
# Publish eval gate (see deploy/linux/README.md §Marketplace registry): a pack
# published without an eval score, or below the floor, lands in
# status=pending_eval and never reaches the tenant catalog. Defaults shown.
# CP_REGISTRY_MIN_EVAL=0.8
# Deliberate bypass — unscored publishes go straight to published:
# CP_REGISTRY_ALLOW_UNSCORED=1

# --- Worker ---------------------------------------------------------------------
# Uncomment only if shell jobs are ever needed (they are NOT, for the rental
# platform — tenant clients get read,write scopes only).
# GBRAIN_ALLOW_SHELL_JOBS=1
